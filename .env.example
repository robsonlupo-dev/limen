APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Reverb (chat em tempo real). O servidor Reverb ainda NÃO é provisionado em
# dev/staging (BROADCAST_CONNECTION=log acima), então estes ficam vazios e o
# front cai no modo "sem tempo real". Preencher só quando o processo Reverb
# subir; aí ligar BROADCAST_CONNECTION=reverb. Ver config/broadcasting.php.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

# Espelham as REVERB_* para o cliente (Echo em resources/js/bootstrap.js). Sem
# VITE_REVERB_APP_KEY o Echo não instancia (degrada limpo).
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@thelimen.com.br"
MAIL_FROM_NAME="Limen"

RESEND_API_KEY=your-api-key-here

# Waitlist nurturing drip. Set START_AT to the activation datetime (ISO 8601) on
# launch so only entries confirmed from then on are enrolled — leaving it empty
# enrolls every already-confirmed entry (only safe on a fresh waitlist).
WAITLIST_NURTURE_START_AT=
WAITLIST_NURTURE_MAX_PER_RUN=200

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# KYC (Fase 5) — Didit
KYC_PROVIDER=fake
KYC_API_KEY=
KYC_WORKFLOW_ID=
KYC_WEBHOOK_SECRET=
KYC_BASE_URL=https://verification.didit.me

# Asaas / PIX (Fase 3)
# dev/staging only: synthetic PIX, no credentials needed. Production MUST set
# ASAAS_DRIVER=http with a real key — booting prod with 'fake' throws by design.
ASAAS_DRIVER=fake
ASAAS_ENV=sandbox
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
